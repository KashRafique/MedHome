{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "preandroid": "node scripts/set-env.js dev",
    "android": "node scripts/run-android.js devDebug",
    "android:dev": "node scripts/run-android.js devDebug",
    "android:prod": "node scripts/run-android.js prodDebug",
    "android:build:dev": "node scripts/set-env.js dev && cd android && ./gradlew assembleDevRelease",
    "android:build:prod": "node scripts/set-env.js prod && cd android && ./gradlew assembleProdRelease",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "start:dev": "node scripts/set-env.js dev && adb reverse tcp:5000 tcp:5000 && react-native start",
    "start:prod": "node scripts/set-env.js prod && react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-native-community/slider": "^5.1.1",
    "@react-navigation/drawer": "^6.7.2",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "axios": "^1.6.5",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-blob-util": "^0.19.9",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-image-picker": "^8.2.1",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-pdf": "^6.7.5",
    "react-native-reanimated": "^3.6.1",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "^3.29.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-video": "^6.0.0-rc.0",
    "react-native-webview": "^13.6.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-native/typescript-config": "0.73.1",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "cross-env": "^10.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.2.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
